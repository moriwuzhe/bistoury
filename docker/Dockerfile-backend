# 后端镜像
FROM openjdk:11-jre-slim

LABEL maintainer="xi <xi@example.com>"

# 设置时区
ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 创建工作目录
WORKDIR /app

# 复制jar包
COPY bistoury-new-backend/target/bistoury-new-backend-1.0.0.jar app.jar

# 暴露端口：8080后端API，3333Agent通信
EXPOSE 8080 3333

# 启动命令
ENTRYPOINT ["java", "-jar", "app.jar", "--spring.profiles.active=prod"]
